<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MISSION // ALLOCATION"
            android:textColor="@color/accent_blue"
            android:textSize="11sp"
            android:letterSpacing="0.4"
            android:textStyle="bold"
            android:layout_marginTop="60dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Book Your Session"
            android:textColor="@color/foreground"
            android:textSize="42sp"
            android:fontFamily="sans-serif-thin"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHOOSE MODULE"
                android:textColor="@color/accent_blue"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/bookingServiceSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_glass"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESSION TYPE"
                android:textColor="@color/accent_blue"
                android:textSize="10sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/bookingTypeSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_glass"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEMPORAL SETTINGS"
                android:textColor="@color/accent_blue"
                android:textSize="10sp"
                android:layout_marginBottom="8dp" />

            <CalendarView
                android:id="@+id/bookingCalendar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:theme="@style/CustomCalendar"
                android:layout_marginBottom="12dp" />

            <Spinner
                android:id="@+id/bookingTimeSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_glass"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTACT UPLINK"
                android:textColor="@color/gold"
                android:textSize="10sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/bookingPhoneInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="+254 700 000 000"
                android:textColorHint="@color/muted"
                android:textColor="@color/foreground"
                android:background="@android:color/transparent"
                android:inputType="phone"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/bookingCostText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KSh 0"
                android:textColor="@color/gold"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="end"
                android:layout_marginBottom="20dp" />

        </LinearLayout>

        <Button
            android:id="@+id/submitBookingBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="Initialize Session Uplink"
            android:textColor="@color/bg"
            android:background="@drawable/bg_button_futuristic"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:layout_marginBottom="40dp" />

    </LinearLayout>
</ScrollView>
