<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageButton
            android:id="@+id/backBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_glass"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/foreground"
            android:contentDescription="Back"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="System Links"
            android:textColor="@color/foreground"
            android:textSize="36sp"
            android:fontFamily="sans-serif-thin"
            android:layout_marginBottom="40dp" />

        <!-- Location Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHYSICAL COORDINATES"
                android:textColor="@color/accent_blue"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Westlands Business District\nNairobi, Kenya"
                android:textColor="@color/foreground"
                android:textSize="17sp"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>

        <!-- Social Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOCIAL GRID"
                android:textColor="@color/gold"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instagram: @lumina.nairobi"
                android:textColor="@color/foreground"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Twitter: @LuminaStudiosKE"
                android:textColor="@color/foreground"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LinkedIn: Lumina Studios East Africa"
                android:textColor="@color/foreground"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Email/Web -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass"
            android:padding="24dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DIGITAL FREQUENCY"
                android:textColor="@color/accent_blue"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="hello@lumina-studios.co.ke\nwww.lumina-studios.co.ke"
                android:textColor="@color/foreground"
                android:textSize="16sp"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>

        <Button
            android:id="@+id/callBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Establish Uplink"
            android:textColor="@color/bg"
            android:background="@drawable/bg_button_futuristic"
            android:textAllCaps="true"
            android:letterSpacing="0.2"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
