<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="32dp">

    <TextView
        android:id="@+id/serviceName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Module Alpha"
        android:textColor="@color/gold"
        android:textSize="32sp"
        android:fontFamily="sans-serif-thin"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp" />

    <TextView
        android:id="@+id/serviceDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="System description and operational parameters for this specific module. Capturing high-fidelity visual data for complex environments."
        android:textColor="@color/foreground"
        android:textSize="18sp"
        android:fontFamily="sans-serif-light"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/serviceName"
        android:layout_marginTop="16dp" />

    <View
        android:id="@+id/divider"
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:background="@color/accent_blue"
        app:layout_constraintTop_toBottomOf="@id/serviceDesc"
        android:layout_marginTop="32dp"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/verificationLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VISUAL VERIFICATION // SAMPLES"
        android:textColor="@color/accent_blue"
        android:textSize="11sp"
        android:letterSpacing="0.3"
        app:layout_constraintTop_toBottomOf="@id/divider"
        android:layout_marginTop="48dp"
        app:layout_constraintStart_toStartOf="parent" />

    <HorizontalScrollView
        android:id="@+id/samplesScroll"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/verificationLabel"
        android:layout_marginTop="20dp">

        <LinearLayout
            android:id="@+id/samplesContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <Button
        android:id="@+id/bookServiceBtn"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Initialize Module Task"
        android:textColor="@color/bg"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:background="@drawable/bg_button_futuristic"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="40dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
