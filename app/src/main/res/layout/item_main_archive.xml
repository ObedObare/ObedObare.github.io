<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="32dp">

    <TextView
        android:id="@+id/archiveLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PHOTO GALLERY"
        android:textColor="@color/accent_blue"
        android:textSize="11sp"
        android:letterSpacing="0.4"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="60dp" />

    <TextView
        android:id="@+id/archiveTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Our Archive"
        android:textColor="@color/foreground"
        android:textSize="42sp"
        android:fontFamily="sans-serif-thin"
        app:layout_constraintTop_toBottomOf="@id/archiveLabel"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/archiveDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Welcome to our collection of past work. Here you can browse through our different photography categories like Portraits, Fashion, and Architecture to see the quality we deliver."
        android:textColor="@color/muted"
        android:textSize="14sp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/archiveTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/archiveRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/archiveDesc"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
