<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <color name="accent_blue">#00F2FF</color>
    <color name="accent_blue_glow">#3300F2FF</color>
    <color name="bg">#05070A</color>
    <color name="border">#1A1F2B</color>
    <color name="foreground">#FFFFFF</color>
    <color name="glass_white">#1AFFFFFF</color>
    <color name="gold">#FFD700</color>
    <color name="gold_dark">#B58E47</color>
    <color name="gold_glow">#4DFFD700</color>
    <color name="muted">#6B7280</color>
    <color name="surface">#0F1219</color>
    <string name="app_name">Lumina Studios</string>
    <style name="CalendarDateText">
        <item name="android:textColor">@color/foreground</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="CalendarWeekText">
        <item name="android:textColor">@color/accent_blue</item>
        <item name="android:textSize">12sp</item>
    </style>
    <style name="CustomCalendar" parent="Theme.AppCompat">
        <item name="android:dateTextAppearance">@style/CalendarDateText</item>
        <item name="android:weekDayTextAppearance">@style/CalendarWeekText</item>
        <item name="android:calendarTextColor">@color/foreground</item>
        <item name="colorAccent">@color/accent_blue</item>
    </style>
    <style name="Theme.LuminaStudios" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/gold_dark</item>
        <item name="colorOnPrimary">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:textColorPrimary">@color/foreground</item>
        <item name="android:textColorSecondary">@color/muted</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/bg</item>
    </style>
</resources>