<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="32dp">

    <TextView
        android:id="@+id/pricingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="COST // PARAMETERS"
        android:textColor="@color/accent_blue"
        android:textSize="11sp"
        android:letterSpacing="0.4"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="60dp" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Pricing"
        android:textColor="@color/foreground"
        android:textSize="36sp"
        android:fontFamily="sans-serif-thin"
        app:layout_constraintTop_toBottomOf="@id/pricingLabel"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pricingRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="100dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintBottom_toBottomOf="parent" />

    <Button
        android:id="@+id/bookSessionBtn"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Initialize Booking"
        android:textColor="@color/bg"
        android:background="@drawable/bg_button_futuristic"
        android:textAllCaps="true"
        android:letterSpacing="0.2"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
