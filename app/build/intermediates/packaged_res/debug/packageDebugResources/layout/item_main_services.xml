<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="32dp">

    <TextView
        android:id="@+id/modulesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OUR SERVICES"
        android:textColor="@color/accent_blue"
        android:textSize="11sp"
        android:letterSpacing="0.4"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="60dp" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Modules"
        android:textColor="@color/foreground"
        android:textSize="42sp"
        android:fontFamily="sans-serif-thin"
        app:layout_constraintTop_toBottomOf="@id/modulesLabel"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/modulesDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Modules are the different types of photography and videography services we offer. Each module is designed to meet your specific needs, from personal portraits to large corporate events."
        android:textColor="@color/muted"
        android:textSize="14sp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/innerServicesRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/modulesDesc"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
