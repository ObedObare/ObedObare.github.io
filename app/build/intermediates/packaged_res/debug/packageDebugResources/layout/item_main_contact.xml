<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTACT &amp; FEEDBACK"
            android:textColor="@color/accent_blue"
            android:textSize="11sp"
            android:letterSpacing="0.4"
            android:textStyle="bold"
            android:layout_marginTop="60dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Talk to Us"
            android:textColor="@color/foreground"
            android:textSize="42sp"
            android:fontFamily="sans-serif-thin"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTACT INFORMATION"
                android:textColor="@color/gold"
                android:textSize="10sp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/callBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Call +254 143 356 401"
                android:textColor="@color/bg"
                android:background="@drawable/bg_button_futuristic"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/emailBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Email: info@lumina.studios"
                android:textColor="@color/foreground"
                android:background="@drawable/bg_glass" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FIND US ON SOCIAL MEDIA"
            android:textColor="@color/accent_blue"
            android:textSize="10sp"
            android:layout_marginBottom="16dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins">

            <Button
                android:id="@+id/tiktokBtn"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="TikTok"
                android:textColor="@color/foreground"
                android:background="@drawable/bg_glass" />

            <Button
                android:id="@+id/instagramBtn"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="Instagram"
                android:textColor="@color/foreground"
                android:background="@drawable/bg_glass" />

            <Button
                android:id="@+id/youtubeBtn"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="YouTube"
                android:textColor="@color/foreground"
                android:background="@drawable/bg_glass" />

            <Button
                android:id="@+id/facebookBtn"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="Facebook"
                android:textColor="@color/foreground"
                android:background="@drawable/bg_glass" />
        </GridLayout>

    </LinearLayout>
</ScrollView>
