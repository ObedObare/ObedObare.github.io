<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Futuristic background element -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/scrim_bottom"
        android:rotation="45"
        android:alpha="0.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="40dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_glass"
                android:alpha="0.5" />

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="Lumina Logo" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LUMINA STUDIOS"
            android:textColor="@color/gold"
            android:letterSpacing="0.5"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textColor="@color/foreground"
            android:textSize="36sp"
            android:fontFamily="sans-serif-thin"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="48dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass"
            android:padding="24dp">

            <EditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Your Name"
                android:textColorHint="@color/muted"
                android:textColor="@color/foreground"
                android:background="@android:color/transparent"
                android:inputType="textPersonName"
                android:visibility="gone" />

            <View
                android:id="@+id/nameDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Email Address"
                android:textColorHint="@color/muted"
                android:textColor="@color/foreground"
                android:background="@android:color/transparent"
                android:inputType="textEmailAddress" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Password"
                android:textColorHint="@color/muted"
                android:textColor="@color/foreground"
                android:background="@android:color/transparent"
                android:inputType="textPassword" />

        </LinearLayout>

        <Button
            android:id="@+id/submitBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="Log In"
            android:textColor="@color/bg"
            android:textAllCaps="true"
            android:letterSpacing="0.2"
            android:textStyle="bold"
            android:background="@drawable/bg_button_futuristic" />

        <TextView
            android:id="@+id/toggleMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New user? Sign up"
            android:textColor="@color/accent_blue"
            android:padding="16dp"
            android:layout_marginTop="16dp" />

        <View
            android:layout_width="100dp"
            android:layout_height="1dp"
            android:background="@color/border"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/adminLoginToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADMIN ACCESS"
            android:textColor="@color/gold"
            android:letterSpacing="0.2"
            android:textSize="10sp"
            android:textStyle="bold"
            android:padding="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
