<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_glass"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ADMIN // TERMINAL"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:letterSpacing="0.4"
            android:textStyle="bold" />

        <Button
            android:id="@+id/logoutBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="EXIT"
            android:textSize="10sp"
            android:textColor="@color/gold"
            android:background="@drawable/bg_glass" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Operational Overview"
                android:textColor="@color/foreground"
                android:textSize="32sp"
                android:fontFamily="sans-serif-thin"
                android:layout_marginBottom="32dp" />

            <!-- Manage Services -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODULE MANAGEMENT"
                    android:textColor="@color/accent_blue"
                    android:textSize="10sp"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/manageServicesBtn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Edit Studio Services"
                    android:background="@drawable/bg_glass"
                    android:textColor="@color/foreground" />
            </LinearLayout>

            <!-- Manage Photos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ARCHIVE CONTROL"
                    android:textColor="@color/gold"
                    android:textSize="10sp"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/managePhotosBtn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Add/Remove Gallery Photos"
                    android:background="@drawable/bg_glass"
                    android:textColor="@color/foreground" />
            </LinearLayout>

            <!-- Manage Bookings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION SCHEDULER"
                    android:textColor="@color/accent_blue"
                    android:textSize="10sp"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/viewBookingsBtn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="View Pending Bookings"
                    android:background="@drawable/bg_glass"
                    android:textColor="@color/foreground" />
            </LinearLayout>

            <!-- System Documentation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KNOWLEDGE BASE"
                    android:textColor="@color/gold"
                    android:textSize="10sp"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/viewDocsBtn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="System Documentation"
                    android:background="@drawable/bg_glass"
                    android:textColor="@color/foreground" />
            </LinearLayout>

            <!-- App Statistics -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM STATUS: ONLINE"
                android:textColor="@color/muted"
                android:textSize="10sp"
                android:layout_marginTop="20dp"
                android:layout_gravity="center" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
